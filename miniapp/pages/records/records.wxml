<view class="container">
  <view wx:if="{{records.length === 0}}" class="empty">暂无签到记录</view>
  <view wx:else class="record-list">
    <view wx:for="{{records}}" wx:key="id" class="record-item">
      <view class="record-left">
        <view class="record-date">{{ item.check_in_date }}</view>
      </view>
      <view class="record-right">
        <view class="record-time">{{ item.check_in_time }}</view>
      </view>
    </view>
  </view>
</view>
