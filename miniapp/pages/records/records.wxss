.container { padding: 16px; }
.empty { text-align: center; padding: 80px 0; color: #999; font-size: 15px; }
.record-item { display: flex; justify-content: space-between; align-items: center; background: #fff; padding: 16px; border-radius: 8px; margin-bottom: 8px; }
.record-date { font-size: 15px; font-weight: 500; }
.record-time { font-size: 13px; color: #999; }
