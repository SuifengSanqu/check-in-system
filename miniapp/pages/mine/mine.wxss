.container { padding: 24px; }
.avatar-area { display: flex; justify-content: center; margin: 32px 0 16px; }
.avatar { width: 80px; height: 80px; border-radius: 50%; }
.avatar-placeholder { width: 80px; height: 80px; border-radius: 50%; background: #ddd; display: flex; justify-content: center; align-items: center; font-size: 32px; color: #999; }
.nickname { text-align: center; font-size: 18px; font-weight: 600; margin-bottom: 40px; }
.stats-box { background: #fff; border-radius: 8px; padding: 16px; }
.stat-row { display: flex; justify-content: space-between; padding: 14px 8px; border-bottom: 1px solid #f5f5f5; }
.stat-row:last-child { border-bottom: none; }
.stat-label { font-size: 15px; }
.stat-num { font-size: 15px; font-weight: 600; color: #4a6cf7; }
